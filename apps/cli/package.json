{
  "name": "@promptlint/cli",
  "version": "0.0.0",
  "private": true,
  "description": "PromptLint command-line interface.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "promptlint": "./bin/promptlint.ts"
  },
  "scripts": {
    "lint": "biome check src bin",
    "lint:fix": "biome check --write src bin",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "echo \"no-op (CLI runs from source via tsx)\" && exit 0",
    "clean": "rm -rf dist .turbo coverage",
    "topo": "echo \"topo\""
  },
  "dependencies": {
    "@promptlint/config": "workspace:*",
    "@promptlint/parser": "workspace:*",
    "@promptlint/reporter-human": "workspace:*",
    "@promptlint/reporter-json": "workspace:*",
    "@promptlint/rule-engine": "workspace:*",
    "@promptlint/rules": "workspace:*",
    "@promptlint/types": "workspace:*",
    "tsx": "4.19.2"
  },
  "devDependencies": {
    "@promptlint/biome-config": "workspace:*",
    "@promptlint/tsconfig": "workspace:*",
    "@types/node": "20.17.10",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
