{
  "name": "@prompt-lint/docs",
  "version": "0.0.0",
  "private": true,
  "description": "PromptLint documentation site.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "build": "echo \"no-op (Phase 0)\" && exit 0",
    "clean": "rm -rf dist .turbo coverage .astro .next",
    "topo": "echo \"topo\""
  },
  "dependencies": {},
  "devDependencies": {
    "@prompt-lint/biome-config": "workspace:*",
    "@prompt-lint/tsconfig": "workspace:*",
    "@types/node": "20.17.10",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
