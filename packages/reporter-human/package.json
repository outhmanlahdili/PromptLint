{
  "name": "@prompt-lint/reporter-human",
  "version": "1.0.0",
  "description": "Human-readable terminal reporter for PromptLint findings.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo coverage",
    "topo": "echo \"topo\""
  },
  "dependencies": {
    "@prompt-lint/types": "workspace:*"
  },
  "devDependencies": {
    "@prompt-lint/biome-config": "workspace:*",
    "@prompt-lint/tsconfig": "workspace:*",
    "@types/node": "20.17.10",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
