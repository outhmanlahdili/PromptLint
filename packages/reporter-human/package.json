{
  "name": "@promptlint/reporter-human",
  "version": "0.0.0",
  "private": true,
  "description": "Human-readable terminal reporter. Phase 0 ships the formatter contract; Phase 2 implements the renderer.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo coverage",
    "topo": "echo \"topo\""
  },
  "dependencies": {
    "@promptlint/types": "workspace:*"
  },
  "devDependencies": {
    "@promptlint/biome-config": "workspace:*",
    "@promptlint/tsconfig": "workspace:*",
    "@types/node": "20.17.10",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
