{
  "name": "@prompt-lint/config",
  "version": "1.0.0",
  "description": "Configuration loader for `promptlint.config.{ts,json}`. Validates with Zod and exposes rule-severity and rule-option overrides.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "!**/*.tsbuildinfo"],
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo coverage",
    "topo": "echo \"topo\""
  },
  "dependencies": {
    "@prompt-lint/types": "workspace:*",
    "picomatch": "2.3.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@prompt-lint/biome-config": "workspace:*",
    "@prompt-lint/tsconfig": "workspace:*",
    "@types/node": "20.17.10",
    "@types/picomatch": "4.0.3",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
