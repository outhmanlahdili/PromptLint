{
  "name": "@promptlint/types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types for PromptLint — file model, findings, severity, rule contract.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo coverage",
    "topo": "echo \"topo\""
  },
  "dependencies": {},
  "devDependencies": {
    "@promptlint/biome-config": "workspace:*",
    "@promptlint/tsconfig": "workspace:*",
    "@types/node": "20.17.10",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
