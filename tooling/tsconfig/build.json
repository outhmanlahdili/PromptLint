{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "exclude": ["dist", "node_modules", "coverage", "test", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
